{
    "name": "postgres-mcp-server",
    "version": "1.0.0",
    "description": "MCP server for PostgreSQL connection",
    "type": "module",
    "main": "build/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node build/server.js",
        "dev": "tsx server.ts",
        "mcp": "node build/index.js",
        "api:dev": "nodemon --watch . --ext ts --exec tsx server.ts",
        "db:setup": "tsx setup-db.ts",
        "migrate:is-read": "tsx migrate-is-read.ts"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^0.6.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^16.4.5",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "jsonwebtoken": "^9.0.3",
        "node-fetch": "^3.3.2",
        "pg": "^8.11.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.11.24",
        "@types/pg": "^8.11.2",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    }
}
